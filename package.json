    "@payloadcms/next": "^3.17.1",
    "@payloadcms/payload-cloud": "^3.17.1",
    "@payloadcms/plugin-cloud-storage": "^3.17.1",
    "@payloadcms/plugin-nested-docs": "^3.17.1",
    "@payloadcms/plugin-redirects": "^3.17.1",
    "@payloadcms/plugin-seo": "^3.17.1",
